; TS7 side-by-side layout: `typescript` is aliased to @typescript/typescript6
; (reports v6.0.2) while typescript-eslint@8.x declares a peer of
; typescript ">=4.8.4 <6.0.0". The mismatch is intentional (ESLint is fed the
; 6.0.3 compiler API on purpose), so peer resolution must be relaxed for
; `npm ci` to succeed - locally and on Railway (NIXPACKS).
legacy-peer-deps=true
