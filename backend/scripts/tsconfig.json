{
  // Editor/type-check config for one-shot CLI scripts run via `npx tsx`.
  // The root tsconfig only includes `src/**/*`, so without this file editors
  // type-check scripts in an inferred project that lacks @types/node, falsely
  // flagging `process`, `Buffer`, `Blob`, `FormData`, `fetch`, and imports.
  // Extends the base options; rootDir is widened to the backend root so scripts
  // may import from ../src, and emit is disabled (scripts are executed by tsx,
  // never compiled). The production build still uses ../tsconfig.json and is
  // unaffected by this file.
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    // TS7 defaults `types` to [] (no auto @types discovery) - list node explicitly.
    "types": ["node"]
  },
  "include": ["**/*.ts", "../../src/data/blog/**/*.ts"]
}
