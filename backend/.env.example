# Backend environment template. Source of truth = src/config/env.ts.
# Copy to .env and fill in real values. NEVER commit the real .env.
# REQUIRED vars crash the process on boot if missing (Zod fail-fast).
# OPTIONAL vars only disable the feature they power when unset.

# ═══════════════════════════════════════════════════════════════
#  REQUIRED — backend will not boot without these
# ═══════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nexus?schema=public"
MONGODB_URI="mongodb+srv://user:password@cluster.example.mongodb.net/?appName=YourApp"
MONGODB_DB="nexus_dev"                       # defaults to "nexus" if unset

# ─── JWT (each >= 32 chars) ──────────────────────────────────
ACCESS_TOKEN_SECRET="generate-64-char-random-hex"
REFRESH_TOKEN_SECRET="generate-64-char-random-hex"

# ─── Google OAuth — client ID required ───────────────────────
GOOGLE_CLIENT_ID="xxxxxxxxxx.apps.googleusercontent.com"

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"         # required (login site origin)
NODE_ENV="development"                        # development | production | test
PORT="3001"

# ═══════════════════════════════════════════════════════════════
#  OPTIONAL — unset = that feature is disabled
# ═══════════════════════════════════════════════════════════════

# ─── App URLs ────────────────────────────────────────────────
BACKEND_URL="https://api.nexus-payment.com"
DASHBOARD_URL="http://localhost:5174"
WALLET_URL="http://localhost:8080"            # wallet app (wallet.nexus-payment.com in prod)
USER_MGMT_URL=""
# Prod only: share the httpOnly refresh cookie across *.nexus-payment.com.
# Leave unset in development.
# COOKIE_DOMAIN=".nexus-payment.com"

# ─── Google OAuth secret (code flow; disabled when absent) ───
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxxxxxxxxxxxxxx"

# ─── Platform admin / sales notifications ────────────────────
# Comma-separated NEXUS platform admin emails (voucher approval alerts).
NEXUS_ADMIN_EMAILS="admin@yourdomain.com,admin2@yourdomain.com"
AGENT_EMAIL="sales@yourdomain.com"            # chat-escalation alert inbox
CONTACT_SALES_INBOX="sales@yourdomain.com"    # "contact sales" form target
INBOUND_EMAIL_SECRET="nxs_email_wh_xxxxxxxxxxxxxxxx"  # required to use the email-inbound webhook

# ─── OpenAI (AI chat) ────────────────────────────────────────
OPENAI_API_KEY="sk-svcacct-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Apollo.io (contact enrichment) ──────────────────────────
APOLLO_API_KEY=""

# ─── Email — SMTP (preferred) or SendPulse HTTP API fallback ─
EMAIL_FROM="no-reply@yourdomain.com"
EMAIL_ASSET_BASE_URL="https://nexus-payment.com"
SMTP_HOST="smtp-pulse.com"
SMTP_PORT="465"                               # defaults to 465
SMTP_USER="your-smtp-user@example.com"
SMTP_PASS="your-smtp-password"
SENDPULSE_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDPULSE_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Microsoft Graph (read Outlook inbox replies) ────────────
MS_TENANT_ID=""
MS_CLIENT_ID=""
MS_CLIENT_SECRET=""
MS_MAILBOX="admin@nexus-payment.com"

# ─── Monday.com CRM ──────────────────────────────────────────
MONDAY_API_TOKEN=""
MONDAY_BOARD_ID=""
MONDAY_COLUMN_MAP=""                          # JSON: logical name -> column ID

# ─── WhatsApp — Meta Cloud API ───────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TOKEN=""
WHATSAPP_VERIFY_TOKEN="pick-any-random-string"
WHATSAPP_APP_SECRET=""
AGENT_WHATSAPP_NUMBER="972XXXXXXXXX"

# ─── InforU — SMS OTP for wallet phone login (backend only) ──
INFORU_USER="your-inforu-username"
INFORU_TOKEN="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
INFORU_BASE_URL="https://capi.inforu.co.il"   # defaults to this; override for tests
INFORU_SENDER="Nexus"                          # OTP SMS sender ID (must be approved by InforU in prod)

# ─── Cloudinary (offer images; backend only, never to frontend) ─
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"

# ─── Payments (legacy Stripe/PayPlus; new work = PayMe) ──────
ACTIVE_PAYMENT_PROVIDER="stripe"               # stripe | payplus
# STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
# STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"

# ─── Agent / AI proxy ────────────────────────────────────────
AGENT_API_URL="https://your-agents-service.up.railway.app"
AGENT_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── Web Push (VAPID) — npx web-push generate-vapid-keys ─────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ─── Member-invite worker tuning ─────────────────────────────
INVITE_WORKER_CONCURRENCY="5"                  # in-flight SendPulse calls (1-50)
INVITE_SEND_RATE_PER_SEC="10"                  # global send rate (1-100)

# ═══════════════════════════════════════════════════════════════
#  Deploy / build infra (not read by app code; Railway + nixpacks)
# ═══════════════════════════════════════════════════════════════
BUILD_ID="20260101-v1"
NIXPACKS_NODE_VERSION="22"

# Frontend passthrough (legacy; the Vite build reads this, not the backend)
VITE_GOOGLE_CLIENT_ID="xxxxxxxxxx.apps.googleusercontent.com"
